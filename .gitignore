# ==============================
# 用户运行时数据（不上传）
# ==============================

# API Key 敏感数据
data/providers.json

# Agent 数据（agent 配置、会话、工作区记忆）
data/agents/

# 工作流运行时数据（workflow 定义 + 执行状态 + 运行历史）
data/workflows/

# 自定义节点索引（用户添加的节点记录，git-logger 模板示例例外）
data/sandbox/_index.json

# 用户界面主题偏好
data/skin-config.json

# 工作流输出目录（output 节点默认输出地址）
data/workflow_output/

# 发布副本暂存（SS1 / users 镜像）
_release/

# 工具权限设置（用户数据）
data/tools/permissions.json
