{
  "name": "4torm",
  "productName": "4torm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run docs:build",
    "dev": "concurrently -n server,vite -c blue,green \"npm run dev:server\" \"npm run dev:vite\"",
    "dev:server": "cd server && npx tsx watch src/index.ts",
    "dev:vite": "vite",
    "electron": "electron electron/main.cjs",
    "electron:dev": "concurrently -k -n server,vite,shell -c blue,green,magenta \"npm run dev:server\" \"npm run dev:vite\" \"wait-on tcp:127.0.0.1:5173 && electron electron/main.cjs\"",
    "start:prod": "cd server && cross-env SERVE_STATIC=1 NODE_ENV=production npx tsx src/index.ts",
    "electron:prod": "cross-env ELECTRON_PROD=1 electron electron/main.cjs",
    "build": "tsc -b && vite build && vitepress build docs",
    "lint": "eslint .",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs --port 5174 --strictPort",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 5174 --strictPort",
    "_comment_postinstall": "已禁用自动下载 Chromium：下载常卡在解压阶段。需要时手动跑 npx playwright install chromium，或把下面的 key 改回 postinstall 即可恢复",
    "_postinstall_disabled": "npx playwright install chromium"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "katex": "^0.17.0",
    "playwright": "^1.55.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "wait-on": "^9.0.10"
  }
}
